{
  "name": "@rippro/judge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "judge": "./dist/cli.js",
    "rippro-judge": "./dist/cli.js",
    "rj": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "SPECIFICATION.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "dev": "node --enable-source-maps dist/cli.js",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "web:build": "npm --prefix web run build",
    "web:dev": "npm --prefix web run dev",
    "web:lint": "npm --prefix web run lint"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "24.5.1",
    "typescript": "5.9.2"
  }
}
